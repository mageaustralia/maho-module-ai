<?php
/** @var Maho_Ai_Block_Adminhtml_Task_View $this */
$task   = $this->getTask();
$helper = Mage::helper('ai');

$statusColors = [
    'pending'    => '#7b8a97',
    'processing' => '#5577aa',
    'complete'   => '#3d8a3d',
    'failed'     => '#c0392b',
    'cancelled'  => '#999',
];
$statusColor = $statusColors[$task->getData('status')] ?? '#333';
?>
<div class="content-header">
    <table cellspacing="0">
        <tr>
            <td><h3 class="icon-head head-edit-form"><?php echo $helper->__('AI Task #%s', $this->escapeHtml($task->getId())) ?></h3></td>
            <td class="form-buttons">
                <a href="<?php echo $this->escapeUrl($this->getBackUrl()) ?>" class="scalable back"><span><?php echo $helper->__('Back') ?></span></a>
            </td>
        </tr>
    </table>
</div>

<div class="entry-edit">
    <div class="entry-edit-head"><h4><?php echo $helper->__('Task Details') ?></h4></div>
    <table class="form-list" cellspacing="0">
        <tr>
            <td class="label"><?php echo $helper->__('Status') ?></td>
            <td class="value"><strong style="color:<?php echo $statusColor ?>">
                <?php echo $this->escapeHtml(ucfirst($task->getData('status'))) ?>
            </strong></td>
            <td class="label"><?php echo $helper->__('Type') ?></td>
            <td class="value"><?php echo $this->escapeHtml(ucfirst($task->getData('task_type'))) ?></td>
        </tr>
        <tr>
            <td class="label"><?php echo $helper->__('Consumer') ?></td>
            <td class="value"><?php echo $this->escapeHtml($task->getData('consumer')) ?></td>
            <td class="label"><?php echo $helper->__('Priority') ?></td>
            <td class="value"><?php echo $this->escapeHtml(ucfirst($task->getData('priority'))) ?></td>
        </tr>
        <tr>
            <td class="label"><?php echo $helper->__('Platform') ?></td>
            <td class="value"><?php echo $this->escapeHtml($task->getData('platform') ?: '—') ?></td>
            <td class="label"><?php echo $helper->__('Model') ?></td>
            <td class="value"><?php echo $this->escapeHtml($task->getData('model') ?: '—') ?></td>
        </tr>
        <tr>
            <td class="label"><?php echo $helper->__('Input Tokens') ?></td>
            <td class="value"><?php echo (int) $task->getData('input_tokens') ?></td>
            <td class="label"><?php echo $helper->__('Output Tokens') ?></td>
            <td class="value"><?php echo (int) $task->getData('output_tokens') ?></td>
        </tr>
        <tr>
            <td class="label"><?php echo $helper->__('Estimated Cost') ?></td>
            <td class="value">$<?php echo number_format((float) $task->getData('estimated_cost'), 6) ?></td>
            <td class="label"><?php echo $helper->__('Retries') ?></td>
            <td class="value"><?php echo (int) $task->getData('retries') ?> / <?php echo (int) $task->getData('max_retries') ?></td>
        </tr>
        <tr>
            <td class="label"><?php echo $helper->__('Queued') ?></td>
            <td class="value"><?php echo $this->escapeHtml($task->getData('created_at')) ?></td>
            <td class="label"><?php echo $helper->__('Completed') ?></td>
            <td class="value"><?php echo $this->escapeHtml($task->getData('completed_at') ?: '—') ?></td>
        </tr>
        <?php if ($task->getData('store_id')): ?>
        <tr>
            <td class="label"><?php echo $helper->__('Store ID') ?></td>
            <td class="value"><?php echo (int) $task->getData('store_id') ?></td>
            <td></td><td></td>
        </tr>
        <?php endif ?>
    </table>
</div>

<?php if ($task->getData('error_message')): ?>
<div class="entry-edit" style="margin-top:16px">
    <div class="entry-edit-head"><h4 style="color:#c0392b"><?php echo $helper->__('Error') ?></h4></div>
    <div style="padding:12px 16px;background:#fff0f0;border:1px solid #f5c6cb;border-radius:3px;font-family:monospace;white-space:pre-wrap;font-size:12px">
        <?php echo $this->escapeHtml($task->getData('error_message')) ?>
    </div>
</div>
<?php endif ?>

<?php if ($task->getData('context')): ?>
<div class="entry-edit" style="margin-top:16px">
    <div class="entry-edit-head"><h4><?php echo $helper->__('Context') ?></h4></div>
    <pre style="padding:12px 16px;background:#f8f8f8;border:1px solid #ddd;border-radius:3px;font-size:12px;overflow:auto"><?php
        $ctx = json_decode($task->getData('context'), true);
        echo $this->escapeHtml(json_encode($ctx, JSON_PRETTY_PRINT));
    ?></pre>
</div>
<?php endif ?>

<?php
$messages = json_decode($task->getData('messages') ?? '[]', true);
if ($messages):
?>
<div class="entry-edit" style="margin-top:16px">
    <div class="entry-edit-head"><h4><?php echo $helper->__('Messages') ?></h4></div>
    <?php foreach ($messages as $msg): ?>
    <div style="margin:8px 16px;padding:10px 14px;background:<?php echo $msg['role'] === 'user' ? '#f0f4ff' : '#f0fff4' ?>;border-radius:4px">
        <strong style="font-size:11px;text-transform:uppercase;color:#666"><?php echo $this->escapeHtml($msg['role']) ?></strong>
        <div style="margin-top:6px;white-space:pre-wrap;font-size:13px"><?php echo $this->escapeHtml(
            strlen($msg['content'] ?? '') > 500 ? substr($msg['content'], 0, 500) . '…' : ($msg['content'] ?? '')
        ) ?></div>
    </div>
    <?php endforeach ?>
</div>
<?php endif ?>

<?php if ($task->getData('response')): ?>
<div class="entry-edit" style="margin-top:16px">
    <div class="entry-edit-head"><h4><?php echo $helper->__('Response') ?></h4></div>
    <?php
    $response = $task->getData('response');
    $isVector = $task->getData('task_type') === Maho_Ai_Model_Task::TYPE_EMBEDDING;
    if ($isVector):
        $vec = json_decode($response, true);
        $dims = is_array($vec) ? count($vec) : 0;
    ?>
    <div style="padding:12px 16px;background:#f8f8f8;border:1px solid #ddd;border-radius:3px;font-size:13px">
        <?php echo $helper->__('Vector with %d dimensions', $dims) ?>
        <?php if ($dims > 0): ?>
        <div style="margin-top:6px;font-family:monospace;font-size:11px;color:#666">
            [<?php echo $this->escapeHtml(implode(', ', array_slice($vec, 0, 8))) ?><?php echo $dims > 8 ? ', …' : '' ?>]
        </div>
        <?php endif ?>
    </div>
    <?php else: ?>
    <div style="padding:12px 16px;background:#f8f8f8;border:1px solid #ddd;border-radius:3px;white-space:pre-wrap;font-size:13px;max-height:400px;overflow:auto">
        <?php echo $this->escapeHtml(strlen($response) > 2000 ? substr($response, 0, 2000) . '…' : $response) ?>
    </div>
    <?php endif ?>
</div>
<?php endif ?>
