<?xml version="1.0"?>
<config>
    <modules>
        <Maho_Ai>
            <version>1.1.1</version>
        </Maho_Ai>
    </modules>

    <global>
        <models>
            <ai>
                <class>Maho_Ai_Model</class>
                <resourceModel>ai_resource</resourceModel>
            </ai>
            <ai_resource>
                <class>Maho_Ai_Model_Resource</class>
                <entities>
                    <task>
                        <table>maho_ai_task</table>
                    </task>
                    <usage>
                        <table>maho_ai_usage</table>
                    </usage>
                    <vector>
                        <table>maho_ai_vector</table>
                    </vector>
                </entities>
            </ai_resource>
        </models>

        <helpers>
            <ai>
                <class>Maho_Ai_Helper</class>
            </ai>
        </helpers>

        <blocks>
            <ai>
                <class>Maho_Ai_Block</class>
            </ai>
        </blocks>

        <resources>
            <maho_ai_setup>
                <setup>
                    <module>Maho_Ai</module>
                    <class>Mage_Core_Model_Resource_Setup</class>
                </setup>
            </maho_ai_setup>
        </resources>

        <ai>
            <consumers>
                <!-- Consumer modules register here in their config.xml -->
            </consumers>
            <providers>
                <!--
                  Built-in providers route through Maho_Ai_Model_Platform_Symfony
                  which wraps the matching symfony/ai-platform Bridge. They don't
                  need <class> / <factory_method> here because the Factory dispatches
                  them via createSymfonyShim() - the registry-driven keys (label,
                  capabilities, model_fetcher_method, sort_order) still apply for
                  the admin UI and model-fetch button.
                -->
                <openai>
                    <label>OpenAI</label>
                    <model_fetcher_method>fetchOpenAi</model_fetcher_method>
                    <capabilities>chat,embed,image</capabilities>
                    <sort_order>10</sort_order>
                </openai>
                <anthropic>
                    <label>Anthropic (Claude)</label>
                    <model_fetcher_method>fetchAnthropic</model_fetcher_method>
                    <capabilities>chat</capabilities>
                    <sort_order>20</sort_order>
                </anthropic>
                <google>
                    <label>Google (Gemini)</label>
                    <model_fetcher_method>fetchGoogle</model_fetcher_method>
                    <capabilities>chat,embed,image</capabilities>
                    <sort_order>30</sort_order>
                </google>
                <mistral>
                    <label>Mistral AI</label>
                    <model_fetcher_method>fetchMistral</model_fetcher_method>
                    <capabilities>chat,embed</capabilities>
                    <sort_order>40</sort_order>
                </mistral>
                <openrouter>
                    <label>OpenRouter</label>
                    <model_fetcher_method>fetchOpenRouter</model_fetcher_method>
                    <capabilities>chat,image</capabilities>
                    <sort_order>50</sort_order>
                </openrouter>
                <ollama>
                    <label>Ollama (Local)</label>
                    <model_fetcher_method>fetchOllama</model_fetcher_method>
                    <capabilities>chat,embed</capabilities>
                    <sort_order>60</sort_order>
                </ollama>
                <generic>
                    <label>Generic (OpenAI-compatible)</label>
                    <capabilities>chat,embed,image</capabilities>
                    <sort_order>70</sort_order>
                </generic>
            </providers>
        </ai>
    </global>

    <adminhtml>
        <translate>
            <modules>
                <Maho_Ai>
                    <files>
                        <default>Maho_Ai.csv</default>
                    </files>
                </Maho_Ai>
            </modules>
        </translate>
        <layout>
            <updates>
                <maho_ai>
                    <file>maho_ai.xml</file>
                </maho_ai>
            </updates>
        </layout>
    </adminhtml>

    <default>
        <maho_ai>
            <general>
                <enabled>1</enabled>
                <default_platform>openai</default_platform>
                <log_requests>0</log_requests>
                <log_level>minimal</log_level>
                <openai_model>gpt-4o</openai_model>
                <anthropic_model>claude-sonnet-4-6</anthropic_model>
                <google_model>gemini-2.0-flash</google_model>
                <mistral_model>mistral-large-latest</mistral_model>
                <openrouter_model>openai/gpt-4o</openrouter_model>
                <ollama_base_url>http://localhost:11434</ollama_base_url>
                <ollama_model>llama3.2</ollama_model>
            </general>
            <queue>
                <enabled>0</enabled>
                <cron_schedule>*/2 * * * *</cron_schedule>
                <max_tasks_per_run>10</max_tasks_per_run>
                <task_timeout>120</task_timeout>
            </queue>
            <limits>
                <daily_token_limit>0</daily_token_limit>
                <monthly_cost_cap>0</monthly_cost_cap>
                <max_tokens_per_request>4096</max_tokens_per_request>
                <rate_limit_per_minute>30</rate_limit_per_minute>
            </limits>
            <safety>
                <injection_detection>1</injection_detection>
                <output_sanitize_html>1</output_sanitize_html>
                <blocked_patterns></blocked_patterns>
                <pii_detection>0</pii_detection>
            </safety>
            <embed>
                <enabled>0</enabled>
                <default_platform>openai</default_platform>
                <target_dimensions>512</target_dimensions>
                <auto_embed_products>0</auto_embed_products>
                <auto_embed_categories>0</auto_embed_categories>
                <openai_model>text-embedding-3-small</openai_model>
                <google_model>text-embedding-004</google_model>
                <mistral_model>mistral-embed</mistral_model>
                <ollama_model>nomic-embed-text</ollama_model>
            </embed>
            <image>
                <enabled>0</enabled>
                <default_platform>openai</default_platform>
                <fallback_placeholder>1</fallback_placeholder>
                <placeholder_url>https://placehold.co/{w}x{h}</placeholder_url>
                <placeholder_width>800</placeholder_width>
                <placeholder_height>600</placeholder_height>
                <openai_model>dall-e-3</openai_model>
                <google_model>imagen-3.0-generate-001</google_model>
            </image>
        </maho_ai>
    </default>
</config>
